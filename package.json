{
  "name": "ParentKey",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --mode=parentDebug --appId com.parentkey.parent",
    "android:parent": "react-native run-android --mode=parentDebug --appId com.parentkey.parent",
    "android:child": "react-native run-android --mode=childDebug --appId com.parentkey.child",
    "android:both": "bash scripts/run-both-apps.sh",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "ios:install": "cd ios/ && pod install && cd ..",
    "prebuild:clean": "expo prebuild --clean",
    "build:android": "eas build --profile preview --platform android",
    "build:android:play": "eas build --profile production --platform android",
    "build:android:play-verify-apk": "eas build --profile production-verify --platform android",
    "apk:debug:parent": "cd android && ./gradlew assembleParentDebug",
    "apk:debug:child": "cd android && ./gradlew assembleChildDebug",
    "apk:release:parent": "cd android && NODE_ENV=production ./gradlew assembleParentRelease",
    "apk:release:child": "cd android && NODE_ENV=production ./gradlew assembleChildRelease",
    "aab:release:parent": "cd android && ./gradlew bundleParentRelease",
    "aab:release:child": "cd android && ./gradlew bundleChildRelease",
    "install:parent": "cd android && ./gradlew installParentDebug",
    "install:child": "cd android && ./gradlew installChildDebug",
    "prebuild:android": "npx expo prebuild --platform android",
    "prebuild:ios": "npx expo prebuild --platform ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native/new-app-screen": "0.86.0",
    "@react-navigation/bottom-tabs": "^7.18.3",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "^56.0.12",
    "expo-camera": "^57.0.1",
    "expo-file-system": "~56.0.8",
    "expo-image-picker": "^57.0.2",
    "expo-modules-core": "^56.0.17",
    "expo-splash-screen": "~56.0.13",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-device-activity": "^0.6.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
