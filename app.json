{
  "name": "ParentKey",
  "displayName": "ParentKey",
  "icon": "./assets/appicon/parent-icon-1024.png",
  "ios": {
    "bundleIdentifier": "org.reactjs.native.example.ParentKey",
    "icon": "./assets/appicon/parent-icon-1024.png"
  },
  "android": {
    "package": "com.parentkey.parent",
    "adaptiveIcon": {
      "foregroundImage": "./assets/appicon/parent-icon-adaptive-foreground.png",
      "backgroundColor": "#FFFFFF"
    },
    "permissions": [
      "android.permission.CAMERA",
      "android.permission.RECORD_AUDIO"
    ]
  },
  "plugins": [
    [
      "react-native-device-activity",
      {
        "appGroup": "group.org.reactjs.native.example.ParentKey"
      }
    ],
    [
      "expo-camera",
      {
        "cameraPermission": "ParentKey Child needs camera access to scan the QR code from your parent's phone."
      }
    ],
    [
      "expo-image-picker",
      {
        "photosPermission": "ParentKey Child needs photo library access so you can choose a profile picture.",
        "cameraPermission": "ParentKey Child needs camera access so you can take a profile picture."
      }
    ],
    "./plugins/withAndroidFlavors.js",
    "expo-splash-screen"
  ],
  "extra": {
    "eas": {
      "build": {
        "experimental": {
          "ios": {
            "appExtensions": [
              {
                "bundleIdentifier": "org.reactjs.native.example.ParentKey.ShieldConfiguration",
                "targetName": "ShieldConfiguration",
                "entitlements": {
                  "com.apple.developer.family-controls": true,
                  "com.apple.security.application-groups": [
                    "group.org.reactjs.native.example.ParentKey"
                  ]
                }
              },
              {
                "bundleIdentifier": "org.reactjs.native.example.ParentKey.ShieldAction",
                "targetName": "ShieldAction",
                "entitlements": {
                  "com.apple.developer.family-controls": true,
                  "com.apple.security.application-groups": [
                    "group.org.reactjs.native.example.ParentKey"
                  ]
                }
              },
              {
                "bundleIdentifier": "org.reactjs.native.example.ParentKey.ActivityMonitorExtension",
                "targetName": "ActivityMonitorExtension",
                "entitlements": {
                  "com.apple.developer.family-controls": true,
                  "com.apple.security.application-groups": [
                    "group.org.reactjs.native.example.ParentKey"
                  ]
                }
              }
            ]
          }
        }
      },
      "projectId": "3d49ef42-320e-4b5f-a9ef-4761b1abcebc"
    }
  },
  "owner": "umairbutt"
}
