# Copy this file to android/keystore.properties (gitignored) and fill in
# the real values. NEVER commit the real keystore.properties or the .jks
# file it points to — losing either one after your first Play Store upload
# means you can never publish an update to that app listing again.
#
# Generate the keystore with (adjust validity/DN as you like):
#
#   keytool -genkeypair -v -keystore android/keystores/upload-keystore.jks \
#     -storetype JKS -alias parentkey-parent -keyalg RSA -keysize 2048 \
#     -validity 10000
#   keytool -genkeypair -v -keystore android/keystores/upload-keystore.jks \
#     -storetype JKS -alias parentkey-child -keyalg RSA -keysize 2048 \
#     -validity 10000
#
# Back up the resulting .jks file AND this properties file together
# somewhere safe (password manager / secure cloud storage).

RELEASE_STORE_FILE=keystores/upload-keystore.jks
RELEASE_STORE_PASSWORD=changeme
RELEASE_KEY_ALIAS_PARENT=parentkey-parent
RELEASE_KEY_PASSWORD_PARENT=changeme
RELEASE_KEY_ALIAS_CHILD=parentkey-child
RELEASE_KEY_PASSWORD_CHILD=changeme
